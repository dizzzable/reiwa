# ═══════════════════════════════════════════════════════════════════════════════
#  reiwa — Environment Configuration
#
#  Reiwa is the user-facing edge service for Rezeis.
#  It connects to rezeis-admin for all business logic.
#
#  Copy this file to .env and fill in the values marked with "change_me".
# ═══════════════════════════════════════════════════════════════════════════════

# - - - - - REIWA CONFIGURATION - - - - - #
# Public domain of the reiwa web/Mini App. Used by the bot to build webApp
# buttons, referral links and payment-return URLs, and by the API for
# CORS / CSRF allow-list.
#
# Format: just the bare host, e.g. `reiwa.example.com`. The protocol is
# inferred — public domains get `https://` (Telegram requires it for
# webApp buttons), `localhost`/`localhost:PORT` and docker service names
# get `http://`. Full URLs (`https://...`) are also accepted.
#
# Single-image note: the API serves the SPA on REIWA_PORT, so same-origin
# browser requests are always accepted by CSRF regardless of this value.
# Set it to the public host users actually open — e.g. `app.example.com`
# in prod (behind the reverse proxy) or `127.0.0.1:5000` for a local
# unified-image test.
REIWA_DOMAIN=change_me
REIWA_HOST=0.0.0.0
REIWA_PORT=5000
# Optional: explicit CORS / CSRF allow-origin for the API. Leave unset to
# derive it from REIWA_DOMAIN (the common case). Set only when the browser
# origin differs from the public domain (e.g. a separate front-end host).
# REIWA_CORS_ORIGIN=

# - - - - - REZEIS CONFIGURATION - - - - - #
# Connection to rezeis-admin panel (source of truth for all business logic).
# REZEIS_HOST without a dot = docker service name → http://<host>:<port>
# (single-VPS default; must match the rezeis container name, which is `rezeis`).
# REZEIS_HOST with a dot = public domain → https://<host> (split-VPS).
REZEIS_HOST=rezeis
REZEIS_PORT=8000
REZEIS_TOKEN=change_me
REZEIS_CADDY_TOKEN=
REZEIS_COOKIE=
# HMAC shared secret for two same-VPS internal hops:
#   1. reiwa-api → rezeis-admin: signs outbound REST/SSE calls
#      (x-request-signature). Optional but recommended.
#   2. reiwa-api → reiwa-bot (inside the docker network): signs the relay
#      of received rezeis webhooks to the bot's internal listener.
# Must be at least 32 characters. Stays inside reiwa — admin does NOT need
# this value (admin authenticates inbound reiwa requests by REZEIS_TOKEN
# and authenticates ITS OWN outbound webhooks by WEBHOOK_SECRET_HEADER →
# REZEIS_WEBHOOK_SECRET below).
REZEIS_INTERNAL_SHARED_SECRET=change_me

# Secret to VERIFY inbound webhooks from rezeis-admin (operator events:
# bot-config changed, per-user notifications, broadcasts). Must equal the
# admin's WEBHOOK_SECRET_HEADER (this is the Remnawave→remnashop
# "REMNAWAVE_WEBHOOK_SECRET" equivalent). admin signs
# `X-Rezeis-Signature: t=<sec>,v1=<hmac>`; reiwa-api receives on
# https://<REIWA_DOMAIN>/api/v1/webhooks/rezeis and relays to the bot
# locally. When unset, the webhook receiver rejects everything.
REZEIS_WEBHOOK_SECRET=change_me

# - - - - - BOT CONFIGURATION - - - - - #
# The bot runs on long-polling (no webhook). It always registers its slash
# commands (setMyCommands) and drops pending updates only on a cold start —
# so there are NO BOT_SETUP_WEBHOOK / BOT_RESET_WEBHOOK / BOT_SETUP_COMMANDS /
# BOT_DROP_PENDING_UPDATES knobs. The Mini App is toggled from the admin panel
# (Bot features), not via env.
BOT_TOKEN=change_me
BOT_SUPPORT_USERNAME=change_me
BOT_DEV_ID=change_me

# ── Local Bot API Server (OPT-IN, for backups > 50 MB) ───────────────────────
# By default the bot uses Telegram's cloud API (50 MB sendDocument cap). To
# deliver large DB backups (up to 2 GB) point the bot at a self-hosted Local
# Bot API Server:
#   1. Get TELEGRAM_API_ID + TELEGRAM_API_HASH from https://my.telegram.org
#   2. Start the server:  docker compose --profile bigfiles up -d
#   3. Set the URL below so the bot routes through it.
# One-time: a bot already used on the cloud API must log out of it before its
# first use on a local server (call the cloud logOut once).
# TELEGRAM_BOT_API_ROOT=http://telegram-bot-api:8081
# TELEGRAM_API_ID=change_me
# TELEGRAM_API_HASH=change_me

# Telegram bot username WITHOUT the leading "@", e.g. RezeisBot.
# Used to build the t.me/<BOT_USERNAME>?start=payment_return deep link that
# brings users back to the bot (and into the Mini App via menu button)
# after returning from a payment provider in Telegram context.
BOT_USERNAME=RezeisBot
# Optional: TCP port for the bot's internal cache-invalidate listener that
# rezeis-admin pushes to over the private docker network. Defaults to 5100;
# only change it on a non-standard local topology. The listener is skipped
# entirely unless REZEIS_INTERNAL_SHARED_SECRET is set.
# BOT_INVALIDATE_PORT=5100

# - - - - - DATABASE - - - - - #
# reiwa is a stateless edge service. The Postgres source of truth lives in
# rezeis-admin and is reached over HTTP via REZEIS_HOST / REZEIS_PORT.
# Reiwa keeps no relational state of its own. All ephemeral state
# (sessions, rate-limit counters, FSM, linking codes, install banners)
# lives in reiwa-redis below.

# - - - - - BRANDING ASSET CACHE (optional) - - - - - #
# Disk mirror of operator branding assets (logo / PWA icon) proxied from
# rezeis-admin under /uploads/branding/*. Lets the brand survive an admin-panel
# outage (fetch-once → serve-from-cache). Defaults to <cwd>/.cache/branding when
# unset; in docker set it to the mounted volume path.
BRANDING_CACHE_DIR=/data/branding-cache

# - - - - - REDIS CONFIGURATION - - - - - #
# Reiwa's own Redis (sessions, rate limiting, bot FSM state)
REDIS_HOST=reiwa-redis
REDIS_PORT=6379
REDIS_NAME=0
REDIS_PASSWORD=change_me

# - - - - - WEB SESSION / COOKIE SECURITY - - - - - #
# Opaque random session id stored in Redis; the cookie is httpOnly + SameSite=Lax.
# REIWA_COOKIE_SECRET is reserved for future signed-cookie use.
REIWA_COOKIE_SECRET=change_me
# Issue session cookies with the `Secure` flag (HTTPS only). In production the
# app forces Secure cookies on regardless; set this to `true` in any HTTPS env.
REIWA_COOKIE_SECURE=true
# Escape hatch: allow non-`Secure` session cookies in production (trusted
# internal network / out-of-band TLS only). Leave `false` unless you know
# exactly why you need it — otherwise the API fails closed at startup rather
# than silently downgrading session security.
REIWA_ALLOW_INSECURE_COOKIES=false

# - - - - - DEGRADED MODE - - - - - #
# Redis backs web sessions, the rate limiter and brute-force detection. In
# production the API fails closed (refuses to start) when Redis is
# unreachable, because booting without it silently disables those
# protections. Set to `true` only to intentionally boot without Redis
# (local smoke tests, emergency degraded operation). Non-production always
# allows degraded boot regardless of this flag.
REIWA_ALLOW_DEGRADED=false

# - - - - - ANONYMOUS SUPPORT CHAT (optional) - - - - - #
# Captcha is now configured from the rezeis admin panel (Support tickets →
# Settings) and fetched by reiwa at runtime — you normally do NOT need to set
# anything here. These env vars are kept only as a legacy seed/fallback for
# the rezeis side; the reiwa edge reads the effective values from rezeis.
SUPPORT_TURNSTILE_SECRET=
SUPPORT_TURNSTILE_SITE_KEY=
