# ════════════════════════════════════════════════════════════════════════════
#  reiwa — Development image
#
#  Differences vs production Dockerfile:
#    • Single stage — no separate build/runtime split. Source is bind-mounted
#      from the host at runtime, so the image only carries Node.js + deps.
#    • `npm install` runs inside the container so native modules (if any)
#      are linked against the alpine image, not Windows.
#    • Default CMD runs `tsx watch` which restarts the process on edits.
#      docker-compose.dev.yml overrides CMD per service (api / bot / worker).
# ════════════════════════════════════════════════════════════════════════════

FROM node:24-alpine
WORKDIR /app

# Install deps first so the layer is cached unless package*.json changes.
COPY package*.json ./
RUN npm install

# Source is bind-mounted at runtime via docker-compose.dev.yml. Copying it
# here would only be useful if you wanted to run the image without compose.
COPY . .

ENV NODE_ENV=development
CMD ["npx", "tsx", "watch", "src/api/main.ts"]
