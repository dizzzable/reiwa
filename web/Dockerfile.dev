# ════════════════════════════════════════════════════════════════════════════
#  reiwa-web — Development image (vite dev server with HMR)
#
#  Runs `vite` directly so source changes on the host reload instantly via
#  the bind-mount declared in docker-compose.dev.yml. No nginx.
# ════════════════════════════════════════════════════════════════════════════

FROM node:24-alpine
WORKDIR /app

COPY package*.json ./
RUN npm install

COPY . .

ENV NODE_ENV=development
EXPOSE 5173
CMD ["npx", "vite", "--host", "0.0.0.0", "--port", "5173"]
